{
  "bot": {
    "name": "TLC Bot",
    "prefix": "/",
    "status": "Protecting the server 🛡️",
    "status_type": "watching",
    "color": 3447003,
    "error_color": 15158332,
    "success_color": 3066993,
    "warning_color": 16776960
  },

  "owners": [
    "1353160030257549372"
  ],

  "security": {
    "anti_spam": {
      "enabled": true,
      "max_messages": 5,
      "time_window_seconds": 5,
      "punishment": "mute",
      "mute_duration_minutes": 10
    },
    "anti_raid": {
      "enabled": true,
      "join_threshold": 10,
      "join_window_seconds": 10,
      "action": "lockdown",
      "new_account_age_days": 7
    },
    "verification": {
      "enabled": true,
      "verified_role_name": "Verified",
      "unverified_role_name": "Unverified",
      "captcha_length": 6,
      "verification_timeout_minutes": 10
    }
  },

  "logging": {
    "enabled": true,
    "log_channel_name": "tff-logs",
    "mod_log_channel_name": "tff-mod-logs",
    "log_message_deletes": true,
    "log_message_edits": true,
    "log_member_joins": true,
    "log_member_leaves": true,
    "log_role_changes": true,
    "log_emoji_changes": true,
    "log_channel_changes": true,
    "log_voice_activity": true,
    "log_nickname_changes": true
  },

  "tickets": {
    "category_name": "Tickets",
    "support_role_name": "Support",
    "ticket_channel_name": "open-a-ticket",
    "max_tickets_per_user": 1,
    "ticket_prefix": "ticket",
    "transcript_channel_name": "ticket-transcripts",
    "ping_support_on_open": true
  },

  "welcome": {
    "enabled": true,
    "channel_name": "welcome",
    "title": "Welcome to the Server! 🎉",
    "description": "Hey {user}, welcome to **{server}**!\nYou are member **#{count}**.",
    "footer": "TFF Bot • Security & Management",
    "image_url": "",
    "thumbnail_url": "",
    "color": 3447003,
    "dm_on_join": false,
    "dm_message": "Welcome to {server}! Please read the rules."
  },

  "goodbye": {
    "enabled": true,
    "channel_name": "goodbye",
    "title": "Goodbye 👋",
    "description": "**{user}** has left the server.\nWe now have **{count}** members.",
    "color": 15158332
  },

  "monitoring": {
    "enabled": true,
    "monitor_channel_name": "server-monitor",
    "update_interval_seconds": 30,
    "alert_channel_name": "tff-alerts",
    "suspicious_activity_threshold": 5
  },

  "deadline_channel": {
    "default_message": "⏰ **DEADLINE REMINDER**\n\nHey {role1} and {role2}!\nThe deadline for **{task}** is: **{deadline}**\n\nPlease make sure everything is submitted on time!"
  },

  "moderation": {
    "default_mute_duration_minutes": 60,
    "max_warn_before_ban": 3,
    "muted_role_name": "Muted"
  }
}
